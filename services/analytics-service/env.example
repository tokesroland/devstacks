APP_NAME=DevStacks-API
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=devstacks
DB_USERNAME=devstacks
DB_PASSWORD=secret

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# MongoDB
MONGODB_URI=mongodb://mongo:27017/devstacks
MONGODB_DATABASE=devstacks

# Queue
QUEUE_CONNECTION=sqs

# AWS / LocalStack
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=eu-central-1
AWS_ENDPOINT_URL=http://localstack:4566

# SQS Queue nevek
SQS_PREFIX=http://localstack:4566/000000000000
SQS_QUEUE_JOBS_SCRAPED=devstacks-jobs-scraped
SQS_QUEUE_JOBS_PROCESSED=devstacks-jobs-processed
SQS_QUEUE_CV_PARSED=devstacks-cv-parsed
SQS_QUEUE_DEMAND_UPDATED=devstacks-demand-updated

# S3
AWS_BUCKET_CV_FILES=devstacks-cv-files
AWS_BUCKET_RAW_HTML=devstacks-raw-html

# Cache
CACHE_DRIVER=redis
SESSION_DRIVER=redis

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:5173

# API Rate limiting (kérés/perc felhasználónként)
RATE_LIMIT_PER_MINUTE=60
